{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.tsx --bundle --outfile=dist/client.js --sourcemap --watch",
    "build": "esbuild src/main.tsx --bundle --outfile=dist/client.js --minify && cp index.html dist/index.html && cp src/index.css dist/index.css",
    "start": "echo \"Open dist/index.html in your browser\"",
    "preview": "echo \"Open dist/index.html in your browser\"",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },

  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
