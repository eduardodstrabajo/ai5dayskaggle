{
  "name": "openrouter-fastapi-proxy-skill",
  "version": "0.1.0",
  "language": "json",
  "description": "Skill descriptor for this project: a FastAPI proxy that forwards chat requests to OpenRouter.",
  "entrypoint": "server.py",
  "env": {
    "OPENROUTER_API_KEY": "required",
    "OPENROUTER_MODEL": "optional (e.g. openai/gpt-oss-120b:free)"
  },
  "requirements": ["fastapi", "uvicorn[standard]", "httpx", "python-dotenv"],
  "snippet": "# POST /api/chat on local dev server (defaults to OPENROUTER_MODEL if not provided)\n\ncurl -X POST http://localhost:8000/api/chat \\n  -H 'Content-Type: application/json' \\
  -d '{"model": null, "messages": [{"role": "user", "content": "Hello from local app"}]}'",
  "usage": [
    "pip install -r requirements.txt",
    "export OPENROUTER_API_KEY=\"YOUR_KEY\"",
    "export OPENROUTER_MODEL=\"openai/gpt-oss-120b:free\"  # optional",
    "uvicorn server:app --host 0.0.0.0 --port 8000"
  ],
  "examples": [
    "curl -X POST http://localhost:8000/api/chat -H 'Content-Type: application/json' -d '{\"model\": null, \"messages\": [{\"role\": \"user\", \"content\": \"Tell me a joke.\"}] }'"
  ],
  "license": "MIT",
  "author": "Copilot"
}
